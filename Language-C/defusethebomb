#include <stdio.h>
#include <stdlib.h>

int* decrypt(int* code, int codeSize, int k, int* returnSize) {
    int *new_arr= malloc(codeSize*sizeof(int));
    *returnSize= codeSize;

    for(int i = 0; i<codeSize; i++){
        if (k==0){
            new_arr[i] == 0;
        }

        int sum =0;
        for(int j=1; j<=abs(k);j++){
        if(k > 0){
            int target_index= (i+j)%codeSize;
            sum+=code[target_index];
        }

        else{
            int target_index = (i-j+codeSize)%codeSize;
            sum+=code[target_index];
        }
        }

        new_arr[i] = sum;

    }

    return new_arr;
}

int main() {
    int code[] = {5, 7, 1, 4};
    int codeSize = 4;
    int k = 3;
    int returnSize;

    int* result = decrypt(code, codeSize, k, &returnSize);

    if (result != NULL) {
        printf("Decrypted array: ");
        for (int i = 0; i < returnSize; i++) {
            printf("%d ", result[i]);
        }
        printf("\n");
        
        free(result);
    }

    return 0;
}


