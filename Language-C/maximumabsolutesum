#include <stdio.h>
#include <stdlib.h>
#include <math.h>

int maxAbsoluteSum(int* nums, int numsSize) {
    int max_ending = nums[0];
    int min_ending = nums[0];
    int max_sum = nums[0];
    int min_sum = nums[0];
    
    for (int i = 1; i < numsSize; i++) {
        if (nums[i] > max_ending + nums[i]) {
            max_ending = nums[i];
        } else {
            max_ending = max_ending + nums[i];
        }
        
        if (nums[i] < min_ending + nums[i]) {
            min_ending = nums[i];
        } else {
            min_ending = min_ending + nums[i];
        }
        
        if (max_ending > max_sum) max_sum = max_ending;
        if (min_ending < min_sum) min_sum = min_ending;
    }
    
    int abs_max = abs(max_sum);
    int abs_min = abs(min_sum);
    
    return (abs_max > abs_min) ? abs_max : abs_min;
}

int main() {
    int nums[] = {1, -3, 2, 3, -4};
    int numsSize = sizeof(nums) / sizeof(nums[0]);
    
    int result = maxAbsoluteSum(nums, numsSize);
    
    printf("The maximum absolute sum is: %d\n", result);
    
    return 0;
}
