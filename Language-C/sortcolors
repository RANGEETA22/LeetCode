#problem- https://leetcode.com/problems/sort-colors/description/


#include <stdio.h>
void sortColors(int* nums, int numsSize) {  //selection sort
    for(int i = 0; i < numsSize; i++){ 
        int min_index = i; 
        for(int j = i + 1; j < numsSize; j++){ 
            if (nums[j] < nums[min_index]){ 
                min_index = j; 
            } 
        } 
        int temp = nums[i]; 
        nums[i] = nums[min_index]; 
        nums[min_index] = temp; 
    } 
}

int main() {
    int arr[] = {2, 0, 2, 1, 1, 0};
    int size = 6;

    sortColors(arr, size);

    for (int i = 0; i < size; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
