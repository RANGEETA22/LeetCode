#problem - https://leetcode.com/problems/maximum-product-subarray/

#include <stdio.h>
int maxProduct(int* nums, int numsSize) {
    int min_product= nums[0];
    int max_product = nums[0];
    int ans= nums[0];

    for (int i=1; i<numsSize; i++){
        if(nums[i] < 0){
        int temp = max_product;
        max_product = min_product;
        min_product= temp;
    }

        if (nums [i] < nums[i] * max_product){
            max_product = nums[i] * max_product;
        }
        else{
            max_product= nums[i];
        }

        if (nums [i] < nums[i] * min_product){
            min_product = nums[i];
        }
        else{
            min_product= nums[i] * min_product;
        }

        if(ans < max_product){
            ans = max_product;
        }
    }

    return ans;
}

int main(){
    int arr[]={2,3,-2,4};
    int size =sizeof(arr)/sizeof(arr[0]);
    
    int result= maxProduct(arr,size);
    
    printf("%d", result);
}

