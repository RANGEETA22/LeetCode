#problem - https://leetcode.com/problems/max-consecutive-ones/submissions/2061443793/

#include <stdio.h>

int findMaxConsecutiveOnes(int* nums, int numsSize) {
    int sum = 0;
    int max_sum = 0;
    
    for (int i = 0; i < numsSize; i++) {
        if (nums[i] == 0) {
            sum = 0;
        } else {
            sum += nums[i];
        }
        
        if (sum > max_sum) {
            max_sum = sum;
        }
    }

    return max_sum;
}

int main() {
    int nums[] = {1, 1, 0, 1, 1, 1, 0, 1};
    int numsSize = sizeof(nums) / sizeof(nums[0]);

    int result = findMaxConsecutiveOnes(nums, numsSize);

    printf("%d\n", result);

    return 0;
}
