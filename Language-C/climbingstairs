#problem- https://leetcode.com/problems/climbing-stairs/

#include <stdio.h>
int climbStairs(int n) {
    if (n <= 3) {
        return n;
    }
    
    int first = 2;  
    int second = 3; 
    
    for (int i = 4; i <=n; i++) {
        int third = first + second;
        first = second;
        second = third;
    }
    
    return second;
}
int main() {
    int steps = 5;
    int result = climbStairs(steps);
    
    printf("%d", result);
    
    return 0;
}
