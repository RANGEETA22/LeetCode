#problem - https://leetcode.com/problems/circular-sentence/submissions/2065339341/

#include <stdio.h>
#include <stdbool.h>
#include <string.h>

bool isCircularSentence(char* sentence) {
    int i =0;
    int length= strlen(sentence);

    if (sentence[0]!=sentence[length-1]){
        return false;
    }

    for(int i =0 ;i<length; i++){
        if(sentence[i] == ' '){
            if (sentence[i - 1] != sentence[i + 1]) {
                return false;
        }

    }   
}
return true;

}
int main() {
    char test1[] = "leetcode exercises sound delightful";
    printf("Test 1: %s\n", isCircularSentence(test1) ? "TRUE" : "FALSE");

    char test2[] = "leetcode exercises wrong sentence";
    printf("Test 2: %s\n", isCircularSentence(test2) ? "TRUE" : "FALSE");

    char test3[] = "heavy rain";
    printf("Test 3: %s\n", isCircularSentence(test3) ? "TRUE" : "FALSE");

    return 0;
}
