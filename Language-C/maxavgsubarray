#problem - https://leetcode.com/problems/maximum-average-subarray-i/submissions/2060838681/

#include <stdio.h>

double findMaxAverage(int* nums, int numsSize, int k) {
    double sum = 0;
    for (int i = 0; i < k; i++) {
        sum += nums[i];
    }

    double max_sum = sum;

    for (int i = k; i < numsSize; i++) {
        sum += -nums[i - k] + nums[i];
        if (sum > max_sum) {
            max_sum = sum;
        }
    }
    return max_sum / k;
}

int main() {
    int nums[] = {1, 12, -5, -6, 50, 3};
    int numsSize = 6;
    int k = 4;

    double result = findMaxAverage(nums, numsSize, k);
    printf("Maximum Average: %f\n", result); 

    return 0;
}
